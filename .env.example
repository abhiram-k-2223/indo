# ──────────────────────────────────────
# INDO — Indian Commodity Market Agent
# Environment Configuration
# Copy this to .env and fill in your values
# ──────────────────────────────────────

# ─── Telegram Alerts ───────────────────
# Get bot token from https://t.me/botfather
TELEGRAM_BOT_TOKEN=
# Your chat ID (message @userinfobot on Telegram)
TELEGRAM_CHAT_ID=

# ─── LLM Narrative Analysis (optional) ─
# Set to "true" to enable, or use --llm flag
LLM_ENABLED=false
# Options: ollama, openai, anthropic
LLM_PROVIDER=ollama
# Model name (e.g. hermes3, llama3, gpt-4o-mini)
LLM_MODEL=hermes3
# API key for OpenAI/Anthropic (not needed for Ollama)
LLM_API_KEY=
# Ollama server URL (default: http://localhost:11434)
OLLAMA_URL=http://localhost:11434

# ─── Fundamental Data (optional) ───────
# Free API key from https://www.eia.gov/opendata/
EIA_API_KEY=
