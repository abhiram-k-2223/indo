# ─── Data Source ────────────────────────
# Set to "angel_one" for MCX data, or "yfinance" for US futures
DATA_SOURCE=yfinance

# ─── Telegram Alerts ───────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── LLM Narrative Analysis (optional) ─
LLM_ENABLED=false
LLM_PROVIDER=llamacpp
LLM_MODEL=any-gguf-model-that-you-got
LLM_API_KEY=
OLLAMA_URL=http://localhost:11434
LLMCPP_URL=http://localhost:8080/v1

# ─── Alert Thresholds (monitor mode) ───
ALERT_THRESHOLD=15
ALERT_INTERVAL=60

# ─── Fundamental Data (optional) ───────
EIA_API_KEY=

# ─── Angel One SmartAPI (for MCX data) ─
# Set DATA_SOURCE=angel_one above to use MCX data.
# Register at https://smartapi.angelone.in to get these.
# ANGEL_API_KEY=
# ANGEL_CLIENT_ID=
# ANGEL_PASSWORD=
# ANGEL_TOTP_SECRET=
